<Window x:Class="JellyfinPotPlayerShell.App.MediaSourceSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请选择播放版本"
        Width="720"
        Height="420"
        MinWidth="560"
        MinHeight="320"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="该条目包含多个媒体版本，请选择要交给 PotPlayer 的文件。" />

        <ListBox x:Name="MediaSourcesList"
                 Grid.Row="1"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#4B5563"
                                   Text="{Binding Path}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,8,0" Padding="18,5" Content="取消" IsCancel="True" />
            <Button Padding="18,5"
                    Content="使用 PotPlayer 播放"
                    IsDefault="True"
                    Click="PlayButton_Click" />
        </StackPanel>
    </Grid>
</Window>
