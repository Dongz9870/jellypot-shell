<Window x:Class="JellyfinPotPlayerShell.App.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jellyfin PotPlayer Shell 首次设置"
        Width="900"
        Height="720"
        MinWidth="760"
        MinHeight="620"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Text="一次完成播放环境设置" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#4B5563"
                       Text="应用会检测 Jellyfin、PotPlayer 和 NAS。创建 M:/T: 只会增加短路径入口，不移动或修改媒体文件。"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="1. Jellyfin Server" Padding="14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="JellyfinUrlTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,8,0"
                                     AutomationProperties.Name="Jellyfin Server URL" />
                            <Button x:Name="DetectJellyfinButton"
                                    Grid.Column="1"
                                    Padding="16,4"
                                    Content="重新检测"
                                    Click="DetectJellyfinButton_Click" />
                        </Grid>
                        <TextBlock x:Name="JellyfinStatusText"
                                   Margin="2,7,0,0"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,12,0,0" Header="2. PotPlayer" Padding="14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PotPlayerPathTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,8,0"
                                     AutomationProperties.Name="PotPlayer 路径" />
                            <Button x:Name="DetectPotPlayerButton"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Padding="16,4"
                                    Content="自动检测"
                                    Click="DetectPotPlayerButton_Click" />
                            <Button Grid.Column="2"
                                    Padding="16,4"
                                    Content="浏览…"
                                    Click="BrowsePotPlayerButton_Click" />
                        </Grid>
                        <TextBlock x:Name="PotPlayerStatusText"
                                   Margin="2,7,0,0"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,12,0,0" Header="3. NAS 和短盘符" Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="电影目录" />
                        <TextBlock Text="\\NAS-SERVER\Media\Movies" />
                        <TextBlock x:Name="MovieNasStatusText"
                                   Margin="0,3,0,0"
                                   Foreground="#4B5563" />
                        <CheckBox x:Name="CreateMovieDriveCheckBox"
                                  Margin="0,7,0,0"
                                  Content="创建或使用 M: 作为电影短路径" />
                        <TextBlock x:Name="MovieDriveStatusText"
                                   Margin="20,3,0,0"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />

                        <Separator Margin="0,12" />

                        <TextBlock FontWeight="SemiBold" Text="电视剧目录" />
                        <TextBlock Text="\\NAS-SERVER\Media\TVShows" />
                        <TextBlock x:Name="TvNasStatusText"
                                   Margin="0,3,0,0"
                                   Foreground="#4B5563" />
                        <CheckBox x:Name="CreateTvDriveCheckBox"
                                  Margin="0,7,0,0"
                                  Content="创建或使用 T: 作为电视剧短路径" />
                        <TextBlock x:Name="TvDriveStatusText"
                                   Margin="20,3,0,0"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#6B7280"
                                   Text="使用当前 Windows 凭据连接，并设置登录时重新连接；应用不会保存 NAS 密码，也不会覆盖已占用盘符。"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <TextBlock x:Name="ValidationText"
                   Grid.Row="2"
                   MinHeight="26"
                   Margin="2,12,0,8"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="3">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#6B7280"
                       Text="选择“稍后设置”后，下次启动会再次显示此向导。" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="18,5"
                        Content="稍后设置"
                        IsCancel="True" />
                <Button x:Name="FinishButton"
                        Padding="18,5"
                        Content="完成设置并打开"
                        IsDefault="True"
                        Click="FinishButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
