<Window x:Class="JellyfinPotPlayerShell.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="720"
        Height="380"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Jellyfin Server URL" />
        <TextBox x:Name="ServerUrlTextBox"
                 Grid.Row="1"
                 Margin="0,8,0,0"
                 AutomationProperties.Name="Jellyfin Server URL" />

        <TextBlock Grid.Row="2"
                   Margin="0,18,0,0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="PotPlayerMini64.exe" />
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PotPlayerPathTextBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     AutomationProperties.Name="PotPlayer 路径" />
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="16,4"
                    Content="自动检测"
                    Click="DetectPotPlayerButton_Click" />
            <Button Grid.Column="2"
                    Padding="16,4"
                    Content="浏览…"
                    Click="BrowsePotPlayerButton_Click" />
        </Grid>

        <CheckBox x:Name="AutoDetectCheckBox"
                  Grid.Row="4"
                  Margin="2,10,0,0"
                  Content="路径失效时自动重新检测 PotPlayer" />
        <TextBlock Grid.Row="5"
                   Margin="2,8,0,0"
                   Foreground="#6B7280"
                   Text="播放器路径只能来自本机设置、自动检测或由你手动选择；网页不能指定 EXE。"
                   TextWrapping="Wrap" />
        <TextBlock x:Name="ValidationText"
                   Grid.Row="6"
                   Margin="2,10,0,0"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="7" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Margin="0,0,8,0" Padding="18,5" Content="取消" IsCancel="True" />
            <Button x:Name="SaveButton"
                    Padding="18,5"
                    Content="保存并打开"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
