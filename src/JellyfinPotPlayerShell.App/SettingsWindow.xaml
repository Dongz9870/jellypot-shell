<Window x:Class="JellyfinPotPlayerShell.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="560"
        Height="230"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Jellyfin Server URL" />
        <TextBox x:Name="ServerUrlTextBox"
                 Grid.Row="1"
                 Margin="0,10,0,0"
                 AutomationProperties.Name="Jellyfin Server URL" />
        <TextBlock x:Name="ValidationText"
                   Grid.Row="2"
                   Margin="2,6,0,0"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3"
                   Margin="2,10,0,0"
                   Foreground="#6B7280"
                   Text="示例：http://127.0.0.1:8096。登录状态保存在本机 WebView2 用户目录中。"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="取消" IsCancel="True" />
            <Button x:Name="SaveButton"
                    Content="保存并打开"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
