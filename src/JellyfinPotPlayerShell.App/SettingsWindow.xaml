<Window x:Class="JellyfinPotPlayerShell.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="920"
        Height="600"
        MinWidth="760"
        MinHeight="500"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="常规">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Jellyfin Server URL" />
                    <TextBox x:Name="ServerUrlTextBox"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             AutomationProperties.Name="Jellyfin Server URL" />

                    <TextBlock Grid.Row="2"
                               Margin="0,18,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="PotPlayerMini64.exe" />
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PotPlayerPathTextBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 AutomationProperties.Name="PotPlayer 路径" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Padding="16,4"
                                Content="自动检测"
                                Click="DetectPotPlayerButton_Click" />
                        <Button Grid.Column="2"
                                Padding="16,4"
                                Content="浏览…"
                                Click="BrowsePotPlayerButton_Click" />
                    </Grid>

                    <CheckBox x:Name="AutoDetectCheckBox"
                              Grid.Row="4"
                              Margin="2,10,0,0"
                              Content="路径失效时自动重新检测 PotPlayer" />
                    <TextBlock Grid.Row="5"
                               Margin="2,8,0,0"
                               Foreground="#6B7280"
                               Text="播放器路径只能来自本机设置、自动检测或由你手动选择；网页不能指定 EXE。"
                               TextWrapping="Wrap" />
                </Grid>
            </TabItem>

            <TabItem Header="路径映射">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Jellyfin 媒体路径映射" />
                    <TextBlock Grid.Row="1"
                               Margin="0,6,0,12"
                               Foreground="#6B7280"
                               Text="播放前按最长前缀匹配。可将 NAS 路径映射为本机盘符；本步骤不会自动创建 M: 或 T: 盘符。"
                               TextWrapping="Wrap" />

                    <DataGrid x:Name="PathMappingsGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="58"
                                                    Header="启用"
                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="150"
                                                Header="说明"
                                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="220"
                                                Header="Jellyfin 路径前缀"
                                                Binding="{Binding ServerPrefix, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="150"
                                                Header="Windows 路径前缀"
                                                Binding="{Binding WindowsPrefix, UpdateSourceTrigger=PropertyChanged}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3"
                                Margin="0,10,0,0"
                                Orientation="Horizontal">
                        <Button Padding="16,4"
                                Content="添加规则"
                                Click="AddPathMappingButton_Click" />
                        <Button Margin="8,0,0,0"
                                Padding="16,4"
                                Content="删除选中规则"
                                Click="DeletePathMappingButton_Click" />
                        <Button Margin="8,0,0,0"
                                Padding="16,4"
                                Content="重新运行新手向导"
                                Click="RunSetupWizardButton_Click" />
                        <Button Margin="8,0,0,0"
                                Padding="16,4"
                                Content="断开本程序创建的盘符"
                                Click="DisconnectManagedDrivesButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="ValidationText"
                   Grid.Row="1"
                   MinHeight="24"
                   Margin="2,10,0,8"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Margin="0,0,8,0" Padding="18,5" Content="取消" IsCancel="True" />
            <Button x:Name="SaveButton"
                    Padding="18,5"
                    Content="保存并打开"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
